# ─── Firebase Configuration ─────────────────────────────────
# Get these from: https://console.firebase.google.com/
#   → Project Settings → General → Your apps → Web app → Config
#
# For local dev: copy to .env and fill in
# For Vercel: set in Vercel Dashboard → Project → Settings → Environment Variables
# All vars MUST start with REACT_APP_ to be exposed to the build

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
REACT_APP_FIREBASE_PROJECT_ID=your-project
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# ─── Admin Emails ───────────────────────────────────────────
# Comma-separated list of emails that bypass allowlist and get
# access to the Admin Panel (approve/revoke other users)
REACT_APP_ADMIN_EMAILS=you@gmail.com,co-admin@gmail.com

# ─── Vercel Deployment Note ─────────────────────────────────
# If Google Auth works locally but fails on Vercel with
# "auth/unauthorized-domain", add your Vercel domain to:
#   Firebase Console → Authentication → Settings → Authorized domains
#   e.g., your-app.vercel.app, your-app-git-main-you.vercel.app
